Project postforge_target_erd {
  database_type: 'PostgreSQL'
  Note: '''
  PostForge target ERD draft.

  Product boundary:
  public board + private report workspace + collector trend data + explicit AI cost control.

  Design rule:
  no AI call on read/view paths. AI work is stored as usage logs and persisted outputs.
  '''
}

Enum account_status {
  ACTIVE
  WITHDRAWN
  SUSPENDED
}

Enum subscription_status {
  ACTIVE
  PAUSED
  CANCELED
  EXPIRED
}

Enum workspace_role {
  OWNER
  MEMBER
}

Enum draft_status {
  DRAFT
  ARCHIVED
  PUBLISHED
}

Enum content_type {
  DISCUSSION
  REPORT
  AI_BRIEF
}

Enum content_visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

Enum content_status {
  PUBLISHED
  HIDDEN
  DELETED
}

Enum collector_job_status {
  STARTED
  SUCCESS
  FAILED
  PARTIAL_SUCCESS
}

Enum api_request_status {
  SUCCESS
  FAILED
  RATE_LIMITED
  TIMEOUT
  SKIPPED
}

Enum circuit_state {
  CLOSED
  OPEN
  HALF_OPEN
}

Enum collected_item_type {
  NEWS_ARTICLE
  BLOG_POST
  OFFICIAL_DOC
  MARKET_SIGNAL
  DISCLOSURE
}

Enum trend_status {
  ACTIVE
  ARCHIVED
  HIDDEN
}

Enum reference_type {
  COLLECTED_ITEM
  TREND_CLUSTER
  EXTERNAL_URL
}

Enum evidence_link_type {
  AUTHOR_SELECTED
  AI_SUGGESTED
  AI_BRIEF_SOURCE
}

Enum ai_operation_type {
  AI_BRIEF_GENERATION
  REPORT_OUTLINE
  SOURCE_SUMMARY
  DRAFT_REWRITE
  COUNTERPOINTS
  TREND_CLUSTER_SUMMARY
}

Enum ai_usage_status {
  STARTED
  SUCCESS
  FAILED
  REJECTED_BY_QUOTA
}

Table accounts {
  id bigint [pk, increment, not null]
  user_id varchar(100) [not null, unique]
  user_pw varchar(255)
  email varchar(255) [not null, unique]
  nickname varchar(50) [not null, unique]
  provider varchar(30) [not null, default: 'LOCAL']
  provider_id varchar(150)
  is_enabled boolean [not null, default: true]
  version bigint [not null, default: 0]
  status account_status [not null, default: 'ACTIVE']
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (provider, provider_id) [unique, name: 'uk_accounts_provider_provider_id']
    status [name: 'idx_accounts_status']
  }

  Note: 'Current implementation identity table. Ownership: auth.'
}

Table account_roles {
  account_id bigint [not null]
  role varchar(30) [not null]

  indexes {
    (account_id, role) [pk, name: 'pk_account_roles']
  }
}

Table subscription_plans {
  id bigint [pk, increment, not null]
  code varchar(40) [not null, unique]
  name varchar(80) [not null]
  monthly_ai_operation_quota int [not null, default: 0]
  monthly_ai_token_quota int [not null, default: 0]
  private_draft_limit int [not null, default: 0]
  saved_trend_bundle_limit int [not null, default: 0]
  report_export_enabled boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Note: 'Plan limits. Public board trust signals are not plan-gated.'
}

Table account_subscriptions {
  id bigint [pk, increment, not null]
  account_id bigint [not null]
  plan_id bigint [not null]
  status subscription_status [not null, default: 'ACTIVE']
  started_at timestamptz [not null, default: `now()`]
  ends_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (account_id, status) [name: 'idx_account_subscriptions_account_status']
  }
}

Table workspaces {
  id bigint [pk, increment, not null]
  owner_account_id bigint [not null]
  name varchar(120) [not null]
  is_default boolean [not null, default: false]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    owner_account_id [name: 'idx_workspaces_owner_account_id']
    (owner_account_id, is_default) [name: 'idx_workspaces_owner_default']
  }

  Note: 'Private report workspace. MVP can create one default workspace per account.'
}

Table workspace_members {
  workspace_id bigint [not null]
  account_id bigint [not null]
  role workspace_role [not null, default: 'OWNER']
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (workspace_id, account_id) [pk, name: 'pk_workspace_members']
    account_id [name: 'idx_workspace_members_account_id']
  }
}

Table drafts {
  id bigint [pk, increment, not null]
  workspace_id bigint [not null]
  author_account_id bigint [not null]
  draft_type content_type [not null, default: 'REPORT']
  visibility_intent content_visibility [not null, default: 'PRIVATE']
  title varchar(200) [not null]
  content text [not null]
  status draft_status [not null, default: 'DRAFT']
  assist_used boolean [not null, default: false]
  published_post_id bigint
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (workspace_id, updated_at) [name: 'idx_drafts_workspace_updated_at']
    (author_account_id, updated_at) [name: 'idx_drafts_author_updated_at']
    status [name: 'idx_drafts_status']
  }

  Note: 'Private writing object before publication.'
}

Table draft_sources {
  id bigint [pk, increment, not null]
  draft_id bigint [not null]
  reference_type reference_type [not null]
  reference_id bigint
  source_url varchar(1000)
  source_name varchar(150)
  title varchar(500) [not null]
  note varchar(500)
  display_order int [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (draft_id, display_order) [name: 'idx_draft_sources_draft_order']
    (reference_type, reference_id) [name: 'idx_draft_sources_reference']
  }
}

Table saved_trend_bundles {
  id bigint [pk, increment, not null]
  workspace_id bigint [not null]
  account_id bigint [not null]
  name varchar(160) [not null]
  description varchar(500)
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (workspace_id, updated_at) [name: 'idx_saved_trend_bundles_workspace_updated_at']
  }
}

Table saved_trend_bundle_items {
  bundle_id bigint [not null]
  trend_cluster_id bigint [not null]
  display_order int [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (bundle_id, trend_cluster_id) [pk, name: 'pk_saved_trend_bundle_items']
  }
}

Table posts {
  id bigint [pk, increment, not null]
  account_id bigint [not null]
  workspace_id bigint
  author_nickname varchar(50) [not null]
  post_type content_type [not null, default: 'DISCUSSION']
  visibility content_visibility [not null, default: 'PUBLIC']
  status content_status [not null, default: 'PUBLISHED']
  title varchar(200) [not null]
  content text [not null]
  summary varchar(500)
  category varchar(30) [not null, default: 'GENERAL']
  assist_used boolean [not null, default: false]
  views bigint [not null, default: 0]
  like_count bigint [not null, default: 0]
  comment_count bigint [not null, default: 0]
  evidence_count int [not null, default: 0]
  latest_evidence_at timestamptz
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (visibility, status, created_at) [name: 'idx_posts_visibility_status_created_at']
    (account_id, created_at) [name: 'idx_posts_account_created_at']
    (workspace_id, updated_at) [name: 'idx_posts_workspace_updated_at']
    (post_type, created_at) [name: 'idx_posts_type_created_at']
    category [name: 'idx_posts_category']
  }

  Note: 'Published content. PUBLIC rows feed the board; PRIVATE rows belong to workspace/report use.'
}

Table post_tags {
  post_id bigint [not null]
  tag varchar(50) [not null]

  indexes {
    (post_id, tag) [pk, name: 'pk_post_tags']
  }
}

Table comments {
  id bigint [pk, increment, not null]
  post_id bigint [not null]
  account_id bigint [not null]
  parent_id bigint
  author_nickname varchar(50) [not null]
  content varchar(1000) [not null]
  status content_status [not null, default: 'PUBLISHED']
  like_count bigint [not null, default: 0]
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (post_id, created_at) [name: 'idx_comments_post_created_at']
    (account_id, created_at) [name: 'idx_comments_account_created_at']
    parent_id [name: 'idx_comments_parent_id']
    status [name: 'idx_comments_status']
  }
}

Table post_like {
  id bigint [pk, increment, not null]
  post_id bigint [not null]
  account_id bigint [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (post_id, account_id) [unique, name: 'uk_post_like_post_account']
    account_id [name: 'idx_post_like_account_id']
  }
}

Table comment_like {
  id bigint [pk, increment, not null]
  comment_id bigint [not null]
  account_id bigint [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (comment_id, account_id) [unique, name: 'uk_comment_like_comment_account']
    account_id [name: 'idx_comment_like_account_id']
  }
}

Table post_file {
  id bigint [pk, increment, not null]
  post_id bigint
  original_file_name varchar(255) [not null]
  saved_file_name varchar(255) [not null]
  file_path varchar(500) [not null]
  file_size bigint
  file_type varchar(100) [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (post_id, created_at) [name: 'idx_post_file_post_created_at']
  }
}

Table post_evidence_links {
  id bigint [pk, increment, not null]
  post_id bigint [not null]
  reference_type reference_type [not null]
  reference_id bigint
  source_url varchar(1000)
  source_name varchar(150)
  title varchar(500) [not null]
  link_type evidence_link_type [not null, default: 'AUTHOR_SELECTED']
  relevance_score decimal(5,4)
  display_order int [not null, default: 0]
  note varchar(500)
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (post_id, display_order) [name: 'idx_post_evidence_links_post_order']
    (reference_type, reference_id) [name: 'idx_post_evidence_links_reference']
  }

  Note: 'Public evidence signal. Not a public trust score.'
}

Table post_trend_links {
  post_id bigint [not null]
  trend_cluster_id bigint [not null]
  relevance_score decimal(5,4)
  link_reason varchar(300)
  calculated_at timestamptz [not null, default: `now()`]

  indexes {
    (post_id, trend_cluster_id) [pk, name: 'pk_post_trend_links']
    (trend_cluster_id, relevance_score) [name: 'idx_post_trend_links_cluster_score']
  }

  Note: 'Precomputed related trend relation. Read path must not call AI.'
}

Table post_rank_scores {
  id bigint [pk, increment, not null]
  post_id bigint [not null]
  scope varchar(40) [not null, default: 'GLOBAL']
  overall_score decimal(12,6) [not null, default: 0]
  recency_score decimal(12,6) [not null, default: 0]
  engagement_score decimal(12,6) [not null, default: 0]
  evidence_score decimal(12,6) [not null, default: 0]
  score_inputs jsonb
  calculated_at timestamptz [not null, default: `now()`]
  expires_at timestamptz

  indexes {
    (post_id, scope) [unique, name: 'uk_post_rank_scores_post_scope']
    (scope, overall_score) [name: 'idx_post_rank_scores_scope_overall']
  }
}

Table collector_sources {
  id bigint [pk, increment, not null]
  name varchar(100) [not null, unique]
  provider varchar(80)
  source_type varchar(40) [not null]
  base_url varchar(500)
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table collector_source_policies {
  source_id bigint [pk, not null]
  enabled boolean [not null, default: true]
  timeout_ms int [not null, default: 3000]
  retry_max_attempts int [not null, default: 2]
  retry_backoff_ms int [not null, default: 500]
  rate_limit_per_minute int
  daily_quota int
  circuit_state circuit_state [not null, default: 'CLOSED']
  opened_reason varchar(500)
  updated_at timestamptz [not null, default: `now()`]
}

Table collector_jobs {
  id bigint [pk, increment, not null]
  source_id bigint [not null]
  keyword varchar(150)
  status collector_job_status [not null]
  request_count int [not null, default: 0]
  item_count int [not null, default: 0]
  started_at timestamptz [not null, default: `now()`]
  ended_at timestamptz
  error_message text

  indexes {
    (source_id, started_at) [name: 'idx_collector_jobs_source_started_at']
    status [name: 'idx_collector_jobs_status']
  }
}

Table collector_api_requests {
  id bigint [pk, increment, not null]
  job_id bigint
  source_id bigint [not null]
  request_key varchar(500)
  status api_request_status [not null]
  http_status int
  duration_ms int
  retry_attempt int [not null, default: 0]
  rate_limited boolean [not null, default: false]
  error_message text
  requested_at timestamptz [not null, default: `now()`]

  indexes {
    (source_id, requested_at) [name: 'idx_collector_api_requests_source_requested_at']
    job_id [name: 'idx_collector_api_requests_job_id']
    status [name: 'idx_collector_api_requests_status']
  }
}

Table collected_items {
  id bigint [pk, increment, not null]
  job_id bigint
  item_type collected_item_type [not null]
  original_link varchar(1000) [not null, unique]
  dedupe_hash varchar(128) [unique]
  title varchar(500) [not null]
  summary varchar(1000)
  content_snippet text
  source_name varchar(150)
  provider varchar(80)
  keyword varchar(150)
  raw_payload jsonb
  quality_level varchar(40)
  published_at timestamptz
  collected_at timestamptz [not null, default: `now()`]

  indexes {
    job_id [name: 'idx_collected_items_job_id']
    item_type [name: 'idx_collected_items_item_type']
    keyword [name: 'idx_collected_items_keyword']
    published_at [name: 'idx_collected_items_published_at']
    collected_at [name: 'idx_collected_items_collected_at']
  }
}

Table trend_clusters {
  id bigint [pk, increment, not null]
  title varchar(300) [not null]
  summary varchar(1000)
  category varchar(40)
  status trend_status [not null, default: 'ACTIVE']
  trend_score decimal(12,6) [not null, default: 0]
  source_count int [not null, default: 0]
  representative_item_id bigint
  first_seen_at timestamptz
  last_seen_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (category, trend_score) [name: 'idx_trend_clusters_category_score']
    last_seen_at [name: 'idx_trend_clusters_last_seen_at']
    status [name: 'idx_trend_clusters_status']
  }

  Note: 'Related trend read model. It can be deterministic first, AI-summarized later.'
}

Table trend_cluster_items {
  trend_cluster_id bigint [not null]
  collected_item_id bigint [not null]
  item_role varchar(40) [not null, default: 'SUPPORTING']
  relevance_score decimal(5,4)
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (trend_cluster_id, collected_item_id) [pk, name: 'pk_trend_cluster_items']
    collected_item_id [name: 'idx_trend_cluster_items_collected_item_id']
  }
}

Table ai_budget_windows {
  id bigint [pk, increment, not null]
  account_id bigint
  plan_id bigint
  scope varchar(40) [not null, default: 'ACCOUNT']
  window_start timestamptz [not null]
  window_end timestamptz [not null]
  operation_quota int [not null, default: 0]
  token_quota int [not null, default: 0]
  used_operations int [not null, default: 0]
  used_tokens int [not null, default: 0]
  estimated_cost_usd decimal(12,6) [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (account_id, window_start, window_end) [name: 'idx_ai_budget_windows_account_window']
    scope [name: 'idx_ai_budget_windows_scope']
  }
}

Table ai_usage_logs {
  id bigint [pk, increment, not null]
  account_id bigint
  workspace_id bigint
  draft_id bigint
  post_id bigint
  budget_window_id bigint
  operation_type ai_operation_type [not null]
  model varchar(100)
  input_tokens int [not null, default: 0]
  output_tokens int [not null, default: 0]
  estimated_cost_usd decimal(12,6) [not null, default: 0]
  status ai_usage_status [not null]
  failure_reason varchar(1000)
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (account_id, created_at) [name: 'idx_ai_usage_logs_account_created_at']
    (operation_type, created_at) [name: 'idx_ai_usage_logs_operation_created_at']
    status [name: 'idx_ai_usage_logs_status']
  }
}

Ref: account_roles.account_id > accounts.id
Ref: account_subscriptions.account_id > accounts.id
Ref: account_subscriptions.plan_id > subscription_plans.id

Ref: workspaces.owner_account_id > accounts.id
Ref: workspace_members.workspace_id > workspaces.id
Ref: workspace_members.account_id > accounts.id

Ref: drafts.workspace_id > workspaces.id
Ref: drafts.author_account_id > accounts.id
Ref: drafts.published_post_id > posts.id
Ref: draft_sources.draft_id > drafts.id
Ref: saved_trend_bundles.workspace_id > workspaces.id
Ref: saved_trend_bundles.account_id > accounts.id
Ref: saved_trend_bundle_items.bundle_id > saved_trend_bundles.id
Ref: saved_trend_bundle_items.trend_cluster_id > trend_clusters.id

Ref: posts.account_id > accounts.id
Ref: posts.workspace_id > workspaces.id
Ref: post_tags.post_id > posts.id
Ref: comments.post_id > posts.id
Ref: comments.account_id > accounts.id
Ref: comments.parent_id > comments.id
Ref: post_like.post_id > posts.id
Ref: post_like.account_id > accounts.id
Ref: comment_like.comment_id > comments.id
Ref: comment_like.account_id > accounts.id
Ref: post_file.post_id > posts.id
Ref: post_evidence_links.post_id > posts.id
Ref: post_trend_links.post_id > posts.id
Ref: post_trend_links.trend_cluster_id > trend_clusters.id
Ref: post_rank_scores.post_id > posts.id

Ref: collector_source_policies.source_id > collector_sources.id
Ref: collector_jobs.source_id > collector_sources.id
Ref: collector_api_requests.job_id > collector_jobs.id
Ref: collector_api_requests.source_id > collector_sources.id
Ref: collected_items.job_id > collector_jobs.id
Ref: trend_clusters.representative_item_id > collected_items.id
Ref: trend_cluster_items.trend_cluster_id > trend_clusters.id
Ref: trend_cluster_items.collected_item_id > collected_items.id

Ref: ai_budget_windows.account_id > accounts.id
Ref: ai_budget_windows.plan_id > subscription_plans.id
Ref: ai_usage_logs.account_id > accounts.id
Ref: ai_usage_logs.workspace_id > workspaces.id
Ref: ai_usage_logs.draft_id > drafts.id
Ref: ai_usage_logs.post_id > posts.id
Ref: ai_usage_logs.budget_window_id > ai_budget_windows.id

Note cost_invariants {
  '''
  Cost invariants:

  1. Post detail read must use post_trend_links/trend_clusters, not AI.
  2. Writing form default suggestions use DB search/read models.
  3. AI assist must create ai_usage_logs.
  4. AI brief generation is batch/admin/system controlled and stored as posts.
  5. Public board trust signals are not plan-gated.
  '''
}
