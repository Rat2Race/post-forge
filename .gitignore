# IDE
.idea/
*.iml
*.iws
*.ipr

# Gradle
.gradle/
build/
out/
!gradle-wrapper.jar

# Application Configuration (contains secrets)
**/src/main/resources/application-secret.yml
**/src/main/resources/application-local.yml
**/src/main/resources/application-dev.yml

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Node (for frontend)
node_modules/
dist/

# env
.env
.env.*
!.env.example

# Bruno local environments
tests/bruno/**/environments/local.bru
tests/bruno/**/.env

# k6 local outputs
tests/k6/results/
tests/k6/*.summary.json

# Generated testing artifacts
# Intentionally ignored: setup can recreate policy/Bruno/k6 generated outputs.
tests/
!tests/
tests/*
!tests/k6/
tests/k6/*
!tests/k6/manual/
tests/k6/manual/*
!tests/k6/manual/.gitkeep
!tests/k6/manual/*.js

# setup run state
# Intentionally ignored: setup execution state and reports are local run outputs.
setup/state/*
!setup/state/.gitkeep
setup/reports/*.md
!setup/reports/.gitkeep

# DB
docker/
redis/

# H2 DB
**/data/*.db
# Gemini CLI internal files
.omx/
.codex-review/
.codex_tmp/
