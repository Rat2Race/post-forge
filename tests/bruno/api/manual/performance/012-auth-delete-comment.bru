meta {
  name: Performance - Auth Delete Comment
  type: http
  seq: 12
  tags: [
    manual
    performance
    auth
    cleanup
  ]
}

delete {
  url: {{baseUrl}}/posts/{{createdPostId}}/comments/{{createdCommentId}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  if (!bru.getVar("perfMaxMs")) bru.setVar("perfMaxMs", bru.getEnvVar("perfMaxMs") || "1000");
}

tests {
  test("returns 200 or 404", function() {
    expect(res.getStatus()).to.be.oneOf([200, 404]);
  });

  test("responds within performance budget", function() {
    expect(res.getResponseTime()).to.be.below(Number(bru.getVar("perfMaxMs")));
  });
}

settings {
  encodeUrl: true
  timeout: 5000
  followRedirects: true
}
