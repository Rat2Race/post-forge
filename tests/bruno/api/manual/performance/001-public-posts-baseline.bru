meta {
  name: Performance - Public Posts Baseline
  type: http
  seq: 1
  tags: [
    manual
    performance
    public
  ]
}

get {
  url: {{baseUrl}}/posts?page={{perfPage}}&size={{perfPageSize}}
  body: none
  auth: none
}

script:pre-request {
  if (!bru.getVar("perfPage")) bru.setVar("perfPage", bru.getEnvVar("perfPage") || "0");
  if (!bru.getVar("perfPageSize")) bru.setVar("perfPageSize", bru.getEnvVar("perfPageSize") || "20");
  if (!bru.getVar("perfMaxMs")) bru.setVar("perfMaxMs", bru.getEnvVar("perfMaxMs") || "1000");
}

tests {
  test("returns 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("responds within performance budget", function() {
    expect(res.getResponseTime()).to.be.below(Number(bru.getVar("perfMaxMs")));
  });

  test("stores first post id when available", function() {
    const body = res.getBody();
    expect(body).to.have.property("content");
    expect(body.content).to.be.an("array");

    if (!bru.getVar("perfPostId") && body.content.length > 0 && body.content[0].id) {
      bru.setVar("perfPostId", String(body.content[0].id));
    }
  });
}

settings {
  encodeUrl: true
  timeout: 5000
  followRedirects: true
}

docs {
  Manual performance baseline for GET /posts. Run repeatedly with Bruno CLI, for example:
  bru run manual/performance/001-public-posts-baseline.bru --env-file ./environments/local.bru --iteration-count 20 --delay 100
}
