meta {
  name: Performance - Auth Create Post
  type: http
  seq: 6
  tags: [
    manual
    performance
    auth
    write
  ]
}

post {
  url: {{baseUrl}}/posts
  body: json
  auth: bearer
}

headers {
  Accept: application/json
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "title": "bruno perf {{perfRunId}}",
    "content": "Bruno performance test content {{perfRunId}}. This post is created by the manual performance collection.",
    "fileIds": []
  }
}

script:pre-request {
  if (!bru.getVar("perfRunId")) bru.setVar("perfRunId", String(Date.now()));
  if (!bru.getVar("perfMaxMs")) bru.setVar("perfMaxMs", bru.getEnvVar("perfMaxMs") || "1000");
}

tests {
  test("returns 201", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("stores created post id", function() {
    const body = res.getBody();
    expect(body).to.have.property("id");
    bru.setVar("createdPostId", String(body.id));
    bru.setVar("perfPostId", String(body.id));
  });

  test("responds within performance budget", function() {
    expect(res.getResponseTime()).to.be.below(Number(bru.getVar("perfMaxMs")));
  });
}

settings {
  encodeUrl: true
  timeout: 5000
  followRedirects: true
}
