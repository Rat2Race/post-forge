meta {
  name: Performance - Auth Update Comment
  type: http
  seq: 10
  tags: [
    manual
    performance
    auth
    write
  ]
}

put {
  url: {{baseUrl}}/posts/{{createdPostId}}/comments/{{createdCommentId}}
  body: json
  auth: bearer
}

headers {
  Accept: application/json
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "parentId": null,
    "content": "Bruno perf comment updated {{perfRunId}}"
  }
}

script:pre-request {
  if (!bru.getVar("perfRunId")) bru.setVar("perfRunId", String(Date.now()));
  if (!bru.getVar("perfMaxMs")) bru.setVar("perfMaxMs", bru.getEnvVar("perfMaxMs") || "1000");
}

tests {
  test("returns 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("responds within performance budget", function() {
    expect(res.getResponseTime()).to.be.below(Number(bru.getVar("perfMaxMs")));
  });
}

settings {
  encodeUrl: true
  timeout: 5000
  followRedirects: true
}
