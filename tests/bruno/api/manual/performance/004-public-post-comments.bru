meta {
  name: Performance - Public Post Comments
  type: http
  seq: 4
  tags: [
    manual
    performance
    public
  ]
}

get {
  url: {{baseUrl}}/posts/{{perfPostId}}/comments?page={{perfPage}}&size={{perfCommentPageSize}}
  body: none
  auth: none
}

script:pre-request {
  if (!bru.getVar("perfPostId")) bru.setVar("perfPostId", bru.getEnvVar("perfPostId") || "9001");
  if (!bru.getVar("perfPage")) bru.setVar("perfPage", bru.getEnvVar("perfPage") || "0");
  if (!bru.getVar("perfCommentPageSize")) bru.setVar("perfCommentPageSize", bru.getEnvVar("perfCommentPageSize") || "50");
  if (!bru.getVar("perfMaxMs")) bru.setVar("perfMaxMs", bru.getEnvVar("perfMaxMs") || "1000");
}

tests {
  test("returns 200 or 404", function() {
    expect(res.getStatus()).to.be.oneOf([200, 404]);
  });

  test("responds within performance budget", function() {
    expect(res.getResponseTime()).to.be.below(Number(bru.getVar("perfMaxMs")));
  });
}

settings {
  encodeUrl: true
  timeout: 5000
  followRedirects: true
}
